rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * CATALYST CATALOG SECURITY RULES
     * 
     * Core Philosophy: 
     * This ruleset implements a robust ownership-based security model. It strictly segregates 
     * public catalog data (Products, Categories) from private user data (Profiles, Carts, Wishlists). 
     * Authorization is primarily driven by the user's authenticated UID and hierarchical path matching.
     *
     * Data Structure:
     * - Public Data: Root collections /products and /categories are globally readable.
     * - Private Data: All user-specific data is nested under /users/{userId}/, enforcing path-based ownership.
     * - Admin Access: Managed via a dedicated /roles_admin/{userId} collection (DBAC pattern).
     *
     * Key Security Decisions:
     * - Prototyping Mode: Schema validation is minimal to allow for rapid iteration. Focus is on 
     *   identifying WHO can access data, not the exact SHAPE of the data.
     * - Relational Integrity: On creation of user-scoped items (CartItems, WishlistItems), rules 
     *   enforce that internal ownership fields match the path wildcards and the requester's UID.
     * - 1:1 Relationships: Carts and Wishlists use the userId as their document ID to enforce 
     *   the singleton constraint per user.
     * - Denormalization for Authorization: User IDs are required to be present on sub-documents 
     *   to allow for fast, non-recursive security checks.
     */

    // --- Global Helper Functions ---

    /** Checks if the requester is authenticated. */
    function isSignedIn() {
      return request.auth != null;
    }

    /** Checks if the requester's UID matches the provided userId. */
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    /** Checks if the document exists and the requester is the owner. Used for updates and deletes. */
    function isExistingOwner(userId) {
      return resource != null && isOwner(userId);
    }

    /** 
     * Checks if the requester has administrative privileges by verifying the existence 
     * of a document in the roles_admin collection. 
     */
    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid));
    }

    // --- Collection Rules ---

    /**
     * @description Rules for user profile documents. Users can manage their own profile.
     * @path /users/{userId}
     * @allow (create) if auth.uid matches {userId}.
     * @deny (update) if auth.uid does not match {userId}.
     * @principle Enforces path-based ownership and self-creation for user profiles.
     */
    match /users/{userId} {
      allow get, list: if isOwner(userId);
      allow create: if isOwner(userId) && request.resource.data.id == userId;
      allow update, delete: if isExistingOwner(userId);

      /**
       * @description Rules for a user's shopping cart. Restricted to a 1:1 relationship via userId.
       * @path /users/{userId}/carts/{cartId}
       * @allow (get) if user is owner and cartId matches userId.
       * @deny (create) if cartId is not equal to userId.
       * @principle Enforces 1:1 relationship and ownership hierarchy.
       */
      match /carts/{cartId} {
        allow get, list: if isOwner(userId) && cartId == userId;
        allow create: if isOwner(userId) && cartId == userId && request.resource.data.userId == userId;
        allow update, delete: if isExistingOwner(userId) && cartId == userId;

        /**
         * @description Rules for items within a shopping cart.
         * @path /users/{userId}/carts/{cartId}/items/{cartItemId}
         * @allow (create) if user owns the parent cart and provides correct denormalized IDs.
         * @deny (list) if requester is not the userId in the path.
         * @principle Uses denormalized ownership fields to verify authorization without parent lookups.
         */
        match /items/{cartItemId} {
          allow get, list: if isOwner(userId);
          allow create: if isOwner(userId) && request.resource.data.userId == userId && request.resource.data.cartId == cartId;
          allow update: if isExistingOwner(userId) && request.resource.data.userId == userId;
          allow delete: if isExistingOwner(userId);
        }
      }

      /**
       * @description Rules for a user's wishlist. Restricted to a 1:1 relationship via userId.
       * @path /users/{userId}/wishlists/{wishlistId}
       * @allow (list) if user is owner and wishlistId matches userId.
       * @deny (delete) if requester is not the owner.
       * @principle Enforces 1:1 relationship and ownership hierarchy.
       */
      match /wishlists/{wishlistId} {
        allow get, list: if isOwner(userId) && wishlistId == userId;
        allow create: if isOwner(userId) && wishlistId == userId && request.resource.data.userId == userId;
        allow update, delete: if isExistingOwner(userId) && wishlistId == userId;

        /**
         * @description Rules for items within a wishlist.
         * @path /users/{userId}/wishlists/{wishlistId}/items/{wishlistItemId}
         * @allow (update) if user owns the parent wishlist and preserves the owner ID.
         * @deny (create) if denormalized wishlistId does not match the path.
         * @principle Validates relational integrity between path and document data.
         */
        match /items/{wishlistItemId} {
          allow get, list: if isOwner(userId);
          allow create: if isOwner(userId) && request.resource.data.userId == userId && request.resource.data.wishlistId == wishlistId;
          allow update: if isExistingOwner(userId) && request.resource.data.userId == userId;
          allow delete: if isExistingOwner(userId);
        }
      }
    }

    /**
     * @description Rules for product categories. Publicly readable, writeable only by admins.
     * @path /categories/{categoryId}
     * @allow (list) for any user (including unauthenticated).
     * @deny (create) if user is not an admin.
     * @principle Public Read with Admin-Only Writes.
     */
    match /categories/{categoryId} {
      allow get, list: if true;
      allow create, update, delete: if isAdmin();
    }

    /**
     * @description Rules for products. Publicly readable for browsing, writeable only by admins.
     * @path /products/{productId}
     * @allow (get) for any user.
     * @deny (update) if user is not an admin.
     * @principle Public Read with Admin-Only Writes.
     */
    match /products/{productId} {
      allow get, list: if true;
      allow create, update, delete: if isAdmin();
    }

    /**
     * @description Rules for admin role designation. DBAC pattern.
     * @path /roles_admin/{userId}
     * @allow (get) if user is checking their own admin status or requester is an admin.
     * @deny (list) for non-admin users to prevent role discovery.
     * @principle Database-Backed Access Control (DBAC) using document existence.
     */
    match /roles_admin/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow list: if isAdmin();
      allow create, update, delete: if isAdmin();
    }
  }
}